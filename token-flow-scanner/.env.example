# Block explorer API keys (optional, for higher rate limits).
# Copy to .env and fill in. Used by benchmark/scripts/fetch_contract_sources.py
# See: https://etherscan.io/apis / https://bscscan.com/apis

ETHERSCAN_API_KEY=
BSCSCAN_API_KEY=
# EXPLORER_API_KEY=   # fallback for some chains

# RPC URLs (optional; 用于 Proxy 时读 implementation 槽，未设则用脚本内置公共 RPC)
# MAINNET_RPC_URL=
# BSC_RPC_URL=
# BASE_RPC_URL=
# ARBITRUM_RPC_URL=
